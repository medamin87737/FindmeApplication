FROM node:20-alpine

WORKDIR /app

RUN npm init -y && npm install --omit=dev axios

COPY seed.js ./seed.js

CMD ["sh", "-c", "attempt=1; max=5; until node seed.js; do if [ \"$attempt\" -ge \"$max\" ]; then echo '❌ Seed failed after retries'; exit 1; fi; echo \"🔄 Retry seed in 10s (attempt $attempt/$max)\"; attempt=$((attempt+1)); sleep 10; done"]
