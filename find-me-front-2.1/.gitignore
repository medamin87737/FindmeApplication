# Node dependencies  
node_modules/  
package-lock.json  
pnpm-lock.yaml  
yarn.lock  

# Angular build outputs  
dist/  
out-tsc/  

# IDE/editor settings  
.vscode/  
.idea/  
*.sublime-project  
*.sublime-workspace  

# Logs & temporary files  
npm-debug.log*  
yarn-debug.log*  
yarn-error.log*  
*.log  

# Environment & secrets  
src/environments/environment.prod.ts  
src/environments/environment.ts  

# Cache & coverage reports  
/.angular/  
/.cache/  
coverage/  

# Compiled TypeScript files  
*.js  
*.js.map  

# Miscellaneous  
.DS_Store  
Thumbs.db  
